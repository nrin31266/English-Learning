# ==============================================================================
# APP / SECURITY
# ==============================================================================
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/english-learning-realm
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ==============================================================================
# SERVICE DISCOVERY / MESSAGING
# ==============================================================================
ENABLE_EUREKA=0
ENABLE_KAFKA=1


# ==============================================================================
# INTERNAL SERVICE API
# ==============================================================================
DICTIONARY_SERVICE_URL=http://localhost:8082
WORKER_API_KEY=


# ==============================================================================
# DATABASE / CACHE
# ==============================================================================
MONGODB_URI=
MONGODB_DB=dictionary_db
REDIS_URL=


# ==============================================================================
# CLOUDINARY STORAGE
# ==============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ==============================================================================
# GOOGLE CLOUD TTS
# ==============================================================================
GOOGLE_APPLICATION_CREDENTIALS=src/cloud/google_tts_key.json


# ==============================================================================
# LLM PROVIDERS
# ==============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DEEPSEEK_API_KEY=


# ==============================================================================
# LOCAL MEDIA STORAGE
# ==============================================================================
AUDIO_SAVE_PATH=src/temp/audio_files


# ==============================================================================
# MEDIA DOWNLOAD LIMITS
# ==============================================================================
MAX_YOUTUBE_DURATION_SECONDS=1800
MAX_AUDIO_SIZE_MB=200


# ==============================================================================
# WHISPERX SPEECH TO TEXT
# ==============================================================================
ENABLE_WHISPERX=1
WHISPER_MODEL=base.en
WHISPER_BATCH_SIZE=1
MAX_CONCURRENT_TRANSCRIBE=1
WHISPER_COMPUTE_TYPE=float16
DROP_WORD_SEGMENTS=1
TORCH_FORCE_WEIGHTS_ONLY_LOAD=0


# ==============================================================================
# LESSON NLP PIPELINE
# ==============================================================================

SPACY_PROGRESS_EVERY=50
LESSON_GENERATION_START_DELAY=2